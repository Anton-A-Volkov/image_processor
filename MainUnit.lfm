      TabOrder = 2
    end
  end
  object pcWorkspace: TPageControl
    Left = 0
    Height = 188
    Top = 101
    Width = 554
    ActivePage = tsResize
    Align = alClient
    TabIndex = 0
    TabOrder = 1
    OnChange = pcWorkspaceChange
    object tsResize: TTabSheet
      Caption = 'Resize'
      ClientHeight = 160
      ClientWidth = 546
      object btnLockDimensions: TSpeedButton
        Left = 188
        Height = 26
        Top = 40
        Width = 26
        AllowAllUp = True
        Down = True
        Flat = True
        GroupIndex = 1
        Images = ilIcons
        ImageIndex = 1
        OnClick = btnLockDimensionsClick
      end
      object lblResizeDescription: TLabel
        Left = 16
        Height = 41
        Top = 112
        Width = 505
        Alignment = taCenter
        AutoSize = False
        Caption = 'Resizes images with preserving aspect ratio to fit one of the dimensions.'
        Layout = tlCenter
      end
      object eNewWidth: TLabeledEdit
        Left = 12
        Height = 23
        Top = 40
        Width = 170
        EditLabel.Height = 15
        EditLabel.Width = 170
        EditLabel.Caption = 'New width, px:'
        TabOrder = 0
        Text = '1024'
        OnChange = eNewWidthChange
      end
      object eNewHeight: TLabeledEdit
        Left = 219
        Height = 23
        Top = 40
        Width = 170
        EditLabel.Height = 15
        EditLabel.Width = 170
        EditLabel.Caption = 'New height, px:'
        TabOrder = 1
        Text = '1024'
        OnChange = eNewHeightChange
      end
      object btnResize: TButton
        Left = 448
        Height = 25
        Top = 39
        Width = 75
        Caption = 'GO!'
        TabOrder = 2
        OnClick = btnResizeClick
      end
    end
    object tsMakeICO: TTabSheet
      Caption = 'Make Windows ICOn'
      ClientHeight = 160
      ClientWidth = 546
      ImageIndex = 1
      object eICOSaveFile: TLabeledEdit
        Left = 12
        Height = 23
