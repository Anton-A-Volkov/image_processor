  OnCreate = FormCreate
  object pnlGetDirectory: TPanel
    Left = 0
    Height = 101
    Top = 0
    Width = 554
    Align = alTop
    ClientHeight = 101
    ClientWidth = 554
    ParentBackground = False
    TabOrder = 0
    object eFolderPath: TLabeledEdit
      Left = 16
      Height = 23
      Top = 30
      Width = 511
      Anchors = [akTop, akLeft, akRight]
      EditLabel.Height = 15
      EditLabel.Width = 511
      EditLabel.Caption = 'Folder with images:'
      TabOrder = 0
    end
    object btnSelectFolder: TButton
      Left = 494
      Height = 23
      Top = 30
      Width = 33
      Anchors = [akTop, akRight]
      Caption = '...'
      TabOrder = 1
      OnClick = btnSelectFolderClick
    end
    object cbRewriteExisting: TCheckBox
      Left = 16
      Height = 19
      Top = 68
      Width = 511
